  "scripts": {
    "dev": "NODE_ENV=development tsx watch server/_core/index.ts",
    "build": "node scripts/generate-sitemap.mjs && node scripts/generate-llms.mjs && vite build && esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist && node scripts/prerender.mjs",
