    "start": "NODE_ENV=production node dist/index.js",
    "check": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run",
    "governance:audit": "node scripts/trust-governance-audit.mjs",
    "seo:audit": "node scripts/seo-agent-audit.mjs",
