    "seo:agent": "node scripts/seo-growth-agent.mjs",
    "seo:agent:apply": "node scripts/seo-growth-agent.mjs --base https://breakyoursolarcontract.com --apply --verify",
    "seo:indexing": "node scripts/seo-indexing-agent.mjs",
    "seo:alert-summary": "node scripts/seo-alert-summary.mjs",
    "smoke:production": "node scripts/production-smoke.mjs",
    "submit:indexnow": "node scripts/submit-indexnow.mjs",
    "db:push": "drizzle-kit generate && drizzle-kit migrate"
