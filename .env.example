# Core runtime authentication. Production startup fails closed when these are
# missing or unsafe. VITE_APP_ID is an identifier, not a secret.
VITE_APP_ID=
VITE_OAUTH_PORTAL_URL=https://manus.im
OAUTH_SERVER_URL=https://api.manus.im

# Generate this from at least 32 random bytes (48+ base64 characters is
# recommended). Rotating it signs every user out.
JWT_SECRET=

DATABASE_URL=
OWNER_OPEN_ID=
# Optional immutable release identifier surfaced by /healthz and /readyz.
RELEASE_SHA=
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Server-only integration secrets. Never prefix these with VITE_ and never commit values.
GHL_WEBHOOK_URL=
OPENROUTER_API_KEY=

# Optional comma-separated IP/CIDR allowlist for known reverse proxies.
# Leave empty unless the deployment ingress addresses are verified.
TRUST_PROXY=

# Never paste a real private key into this file. Store the complete, rotated
# service-account JSON as a runtime/GitHub Actions secret.
GOOGLE_SERVICE_ACCOUNT_JSON=

# GSC property identifiers are either sc-domain:example.com or an exact URL
# prefix such as https://example.com/.
GSC_PROPERTY_URL=sc-domain:breakyoursolarcontract.com
GSC_DATE_RANGE_DAYS=28
GSC_DATA_LAG_DAYS=3
GSC_MAX_AGE_HOURS=36
