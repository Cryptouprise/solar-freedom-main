# Server-only integration secrets. Never prefix these with VITE_ and never commit values.
GHL_WEBHOOK_URL=
OPENROUTER_API_KEY=
PRLOG_API_KEY=
PRLOG_EMAIL=
PRLOG_PASSWORD=
NEWSBYWIRE_API_KEY=
NEWSBYWIRE_EMAIL=
NEWSBYWIRE_PASSWORD=
OPENPR_EMAIL=
OPENPR_PASSWORD=

# Optional comma-separated IP/CIDR allowlist for known reverse proxies.
# Leave empty unless the deployment ingress addresses are verified.
TRUST_PROXY=

# Never paste a real private key into this file. Store the complete, rotated
# service-account JSON as a runtime/GitHub Actions secret.
GOOGLE_SERVICE_ACCOUNT_JSON=

# GSC property identifiers are either sc-domain:example.com or an exact URL
# prefix such as https://example.com/.
GSC_PROPERTY_URL=sc-domain:breakyoursolarcontract.com
GSC_DATE_RANGE_DAYS=28
GSC_DATA_LAG_DAYS=3
GSC_MAX_AGE_HOURS=36
